# Variáveis consumidas pelo docker-compose.cloud.yml (substituição ${VAR:-default}).
# Em produção, estes valores vêm dos GitHub Secrets e são escritos em .env pelo workflow.
# Para rodar local, copie para .env e ajuste. Sem .env, o compose usa os defaults embutidos.

# Postgres
POSTGRES_USER=Your_username
POSTGRES_PASSWORD=Your_password123
POSTGRES_DB=Your_database

# Redis
REDIS_PASSWORD=Your_redis_password

# RabbitMQ
RABBITMQ_USER=Your_username
RABBITMQ_PASSWORD=Your_password123

# API (HookSentry.Cloud.Host)
JWT_KEY=
API_KEY=change-this-api-key
CREDENTIAL_ENCRYPTION_KEY=
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
