{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Cors": {
        "AllowedOrigin": "https://app.hooksentry.com"
    },
    "Jwt": {
        "Issuer": "hooksentry-api",
        "Audience": "hooksentry-client"
    },
    "RabbitMq": {
        "Port": 5672,
        "VirtualHost": "/",
        "EventsExchange": "hooksentry.events"
    },
    "Otel": {
        "ServiceName": "hooksentry-api"
    },
    "CloudProtection": {
        "EventRetention": {
            "Enabled": true,
            "RetentionDays": 7
        }
    }
}
